  <robot name="Balro4">

	<link name="base_link">
		<visual>
		    <origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<box size="0.28 0.0635 0.1778"/>
			</geometry>
			<material name="Cyan1">
	       		<color rgba="0 0.9 0.9 1.0"/>
	     	</material>
		</visual>

        <collision>
  			<origin xyz="0 0 0" rpy="0 0 0"/>
  			<geometry>
    			<box size="0.28 0.0635 0.1778"/>
  			</geometry>
		</collision>

		<inertial>
            <mass value="2.95"/>
            <inertia ixx="0.00876" iyy="0.027" izz="0.02" ixy="0" ixz="0" iyz="0"/>
        </inertial>
   	</link>



	<link name="wheel_link1">
		<visual>
		    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
			<geometry>
				<cylinder radius="0.1016" length="0.04"/>
			</geometry>
			<material name="Cyan1">
	       		<color rgba="0 0.9 0.9 1.0"/>
	     	</material>
		</visual>	

        <collision>
            <origin xyz="0 0 0" rpy="0 1.5708 0"/>
            <geometry>
                <cylinder radius="0.1016" length="0.04"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.0317"/>
            <inertia ixx="0.00004" iyy="0.00002" izz="0.00002" ixy="0" ixz="0" iyz="0"/>
        </inertial>
	</link>


	<joint name="joint_wheel1" type="continuous">
  		<parent link="base_link"/>
  		<child link="wheel_link1"/>
  		<origin xyz="0.185 0 -0.0635" rpy="0 0 0"/> <!-- attach to base -->
  		<axis xyz="1 0 0"/>
  		<limit effort="1.57" velocity="12.77" lower="-3.14" upper="3.14"/>
	</joint>

	<link name="wheel_link2">
		<visual>
		    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
			<geometry>
				<cylinder radius="0.1016" length="0.04"/>
			</geometry>
			<material name="Cyan1">
	       		<color rgba="0 0.9 0.9 1.0"/>
	     	</material>
		</visual>	

        <collision>
            <origin xyz="0 0 0" rpy="0 1.5708 0"/>
            <geometry>
                <cylinder radius="0.1016" length="0.04"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.0317"/>
            <inertia ixx="0.00004" iyy="0.00002" izz="0.00002" ixy="0" ixz="0" iyz="0"/>
        </inertial>
	</link>


	<joint name="joint_wheel2" type="continuous">
  		<parent link="base_link"/>
  		<child link="wheel_link2"/>
  		<origin xyz="-0.185 0 -0.0635" rpy="0 0 0"/> <!-- attach to base -->
  		<axis xyz="1 0 0"/>
  		<limit effort="1.57" velocity="12.77" lower="-3.14" upper="3.14"/>
	</joint>

	<link name="pendulum_link1">
		<visual>
		    <origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<box size="0.019 0.019 0.6"/>
			</geometry>
			<material name="Cyan1">
	       		<color rgba="0 0.9 0.9 1.0"/>
	     	</material>
		</visual>

        <collision>
  			<origin xyz="0 0 0" rpy="0 0 0"/>
  			<geometry>
    			<box size="0.019 0.019 0.6"/>
  			</geometry>
		</collision>

		<inertial>
            <mass value="1.67"/>
            <inertia ixx="0.14" iyy="0.14" izz="0.0004475" ixy="0" ixz="0" iyz="0"/>
        </inertial>
   	</link>

	<joint name="pendulum_joint1" type="fixed">
  		<parent link="base_link"/>
  		<child link="pendulum_link1"/>
  		<origin xyz="0.0 0.041 0.21" rpy="0 0 0"/> <!-- attach to base -->
	</joint>

	<link name="pendulum_link2">
		<visual>
		    <origin xyz="0 0 0" rpy="0 0 0"/>
			<geometry>
				<box size="0.019 0.019 0.6"/>
			</geometry>
			<material name="Cyan1">
	       		<color rgba="0 0.9 0.9 1.0"/>
	     	</material>
		</visual>

        <collision>
  			<origin xyz="0 0 0" rpy="0 0 0"/>
  			<geometry>
    			<box size="0.019 0.019 0.6"/>
  			</geometry>
		</collision>

		<inertial>
            <mass value="1.67"/>
            <inertia ixx="0.14" iyy="0.14" izz="0.0004475" ixy="0" ixz="0" iyz="0"/>
        </inertial>
   	</link>

	<joint name="pendulum_joint2" type="fixed">
  		<parent link="base_link"/>
  		<child link="pendulum_link2"/>
  		<origin xyz="0.0 -0.041 0.21" rpy="0 0 0"/> <!-- attach to base -->
	</joint>



	<link name="pendulum_weight_link">
		<visual>
		    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
			<geometry>
				<cylinder radius="0.07" length="0.1"/>
			</geometry>
			<material name="Cyan1">
	       		<color rgba="0 0.9 0.9 1.0"/>
	     	</material>
		</visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 1.5708 0"/>
            <geometry>
                <cylinder radius="0.07" length="0.1"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="1.5"/>
            <inertia ixx="0.0036" iyy="0.003" izz="0.003" ixy="0" ixz="0" iyz="0"/>
        </inertial>
	</link>

	<joint name="pendulum_weight_joint" type="fixed">
  		<parent link="pendulum_link1"/>
  		<child link="pendulum_weight_link"/>
  		<origin xyz="0 -0.041 0.302" rpy="0 0 0"/> <!-- attach to base -->
  		<axis xyz="1 0 0"/>
  		<limit effort="10.0" velocity="5.0" lower="-3.14" upper="3.14"/>
	</joint>

 </robot>